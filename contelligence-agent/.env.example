# =============================================================================
# Contelligence Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# -----------------------------------------------------------------------------
# Azure Storage
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
# Credential type: "default_azure_credential" or "account_key"
AZURE_STORAGE_CREDENTIAL_TYPE=default_azure_credential
# Only required when AZURE_STORAGE_CREDENTIAL_TYPE=account_key
AZURE_STORAGE_KEY=

# -----------------------------------------------------------------------------
# Azure Cognitive Search
# -----------------------------------------------------------------------------
AZURE_SEARCH_ACCOUNT_NAME=your-search-account-name
# Credential type: "default_azure_credential" or "api_key"
AZURE_SEARCH_CREDENTIAL_TYPE=default_azure_credential
# Only required when AZURE_SEARCH_CREDENTIAL_TYPE=api_key
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_API_VERSION=2024-07-01

# -----------------------------------------------------------------------------
# Azure Cosmos DB
# -----------------------------------------------------------------------------
AZURE_COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-key
AZURE_COSMOS_DATABASE=contelligence-agent

# -----------------------------------------------------------------------------
# Azure Document Intelligence
# -----------------------------------------------------------------------------
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=your-doc-intelligence-key

# -----------------------------------------------------------------------------
# Azure OpenAI (BYOK — optional, used as custom provider for Copilot SDK)
# If set, the Copilot SDK will use this Azure OpenAI endpoint instead of its
# default model provider.
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_API_VERSION=2024-10-21

# -----------------------------------------------------------------------------
# GitHub Copilot SDK
# -----------------------------------------------------------------------------
# GitHub Personal Access Token with 'copilot' scope
GITHUB_COPILOT_TOKEN=ghp_your-github-token
# Path to the Copilot CLI executable (default: "copilot")
COPILOT_CLI_PATH=copilot
# URL of an existing Copilot CLI server (leave empty for stdio transport)
COPILOT_CLI_URL=
# Default LLM model for agent sessions
COPILOT_MODEL=claude-opus-4.6

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
SESSION_TIMEOUT_MINUTES=60

# -----------------------------------------------------------------------------
# Audio (Azure Speech Services)
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# -----------------------------------------------------------------------------
# Phase 2 — Persistent Sessions
# -----------------------------------------------------------------------------
# Tool result size threshold for blob offloading (KB). Results larger than
# this value are stored in Blob Storage instead of inline in Cosmos DB.
LARGE_RESULT_THRESHOLD_KB=50
# Blob container name for session outputs and offloaded tool results.
AGENT_OUTPUTS_CONTAINER=agent-outputs
# Note: AZURE_COSMOS_ENDPOINT, AZURE_COSMOS_KEY, AZURE_COSMOS_DATABASE
# are already defined above and reused by Phase 2.

# -----------------------------------------------------------------------------
# Phase 3 — MCP Server
# -----------------------------------------------------------------------------
# Leave AZURE_MCP_SERVER_URL empty for stdio mode (subprocess inside container).
# Set to the sidecar URL (e.g., http://azure-mcp:5008) for HTTP mode.
AZURE_MCP_SERVER_URL=
# Disable Microsoft-collected telemetry (default: false)
AZURE_MCP_COLLECT_TELEMETRY_MICROSOFT=false
# Route MCP telemetry to your Application Insights instance
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Azure Key Vault URL for storing the GitHub PAT secret
KEY_VAULT_URL=

# Azure OpenAI embeddings deployment name
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large
# Azure OpenAI chat deployment name
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Approval timeout in seconds (default: 300 = 5 minutes)
APPROVAL_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Phase 4 — RBAC (Azure AD / Entra ID)
# -----------------------------------------------------------------------------
# Set to true to enable JWT validation. When false, a dev admin user is injected.
AUTH_ENABLED=false
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=

# -----------------------------------------------------------------------------
# Phase 4 — Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_OPENAI_RPM=60
RATE_LIMIT_DOC_INTEL_RPM=15

# -----------------------------------------------------------------------------
# Phase 4 — Session Quotas
# -----------------------------------------------------------------------------
SESSION_MAX_TOOL_CALLS=200
SESSION_MAX_DOCUMENTS=100
SESSION_MAX_TOKENS=500000

# -----------------------------------------------------------------------------
# Phase 4 — Extraction Caching
# -----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL_DAYS=7

# -----------------------------------------------------------------------------
# Phase 4 — Session Retention
# -----------------------------------------------------------------------------
SESSION_RETENTION_DAYS=90
BLOB_ARCHIVE_DAYS=90
BLOB_DELETE_DAYS=730

# -----------------------------------------------------------------------------
# Phase 4 — Horizontal Scaling
# -----------------------------------------------------------------------------
MAX_REPLICAS=10
