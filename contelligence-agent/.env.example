# =============================================================================
# Contelligence Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables map to fields in AppSettings (app/settings.py).
#
# Layout:
#   1. App operational config  (server, storage mode, auth, quotas, etc.)
#   2. Service endpoints & keys (Azure services, Copilot SDK, tool connectors)

# ═════════════════════════════════════════════════════════════════════════════
# 1. APP OPERATIONAL CONFIG
# ═════════════════════════════════════════════════════════════════════════════

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
API_VERSION=v1
API_HOST=0.0.0.0
API_PORT=8081
LOG_LEVEL=INFO
SESSION_TIMEOUT_MINUTES=60

# -----------------------------------------------------------------------------
# Storage Mode
# -----------------------------------------------------------------------------
# "azure" for cloud deployment (Cosmos DB + Blob Storage),
# "local" for standalone desktop (SQLite + filesystem blobs).
STORAGE_MODE=azure
LOCAL_DATA_DIR=                    # Local data directory (SQLite DB, blobs, logs)

# -----------------------------------------------------------------------------
# Working Directory & Skills
# -----------------------------------------------------------------------------
# Working directory the SDK uses for tool operations (e.g. /workspace in Docker)
WORKING_DIRECTORY=

# Single writable path where all skills (built-in + user-created) are
# materialized on disk. The SDK and CLI discover skills from this directory.
# Docker: /shared/skills  |  Electron: <userData>/skills  |  Empty: built-in dir only
SHARED_SKILLS_DIRECTORY=

# -----------------------------------------------------------------------------
# RBAC (Entra ID)
# -----------------------------------------------------------------------------
# Set to true to enable JWT validation. When false, a dev admin user is injected.
AUTH_ENABLED=false
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=

# -----------------------------------------------------------------------------
# Persistent Sessions
# -----------------------------------------------------------------------------
# Tool result size threshold for blob offloading (KB)
LARGE_RESULT_THRESHOLD_KB=50
# Blob container for session outputs and offloaded tool results
AGENT_OUTPUTS_CONTAINER=agent-outputs

# -----------------------------------------------------------------------------
# Session Quotas
# -----------------------------------------------------------------------------
SESSION_MAX_TOOL_CALLS=200
SESSION_MAX_DOCUMENTS=100
SESSION_MAX_TOKENS=500000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_OPENAI_RPM=60
RATE_LIMIT_DOC_INTEL_RPM=15

# -----------------------------------------------------------------------------
# Extraction Caching
# -----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL_DAYS=7

# -----------------------------------------------------------------------------
# Session Retention
# -----------------------------------------------------------------------------
SESSION_RETENTION_DAYS=90
BLOB_ARCHIVE_DAYS=90
BLOB_DELETE_DAYS=730

# -----------------------------------------------------------------------------
# Approval
# -----------------------------------------------------------------------------
APPROVAL_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Agent Registry
# -----------------------------------------------------------------------------
DYNAMIC_REGISTRY_CACHE_TTL_SECONDS=60

# -----------------------------------------------------------------------------
# Horizontal Scaling
# -----------------------------------------------------------------------------
MAX_REPLICAS=10

# -----------------------------------------------------------------------------
# Scheduling Engine
# -----------------------------------------------------------------------------
AGENT_BASE_URL=http://localhost:8060
SCHEDULE_AUTO_PAUSE_THRESHOLD=3
SCHEDULER_MISFIRE_GRACE_TIME=60

# ═════════════════════════════════════════════════════════════════════════════
# 2. SERVICE ENDPOINTS & KEYS
# ═════════════════════════════════════════════════════════════════════════════

# -----------------------------------------------------------------------------
# Application Storage — Cosmos DB (Azure mode)
# -----------------------------------------------------------------------------
APP_STORAGE_DATABASE=contelligence # Cosmos DB database name (or SQLite file name without .db)
APP_STORAGE_COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
APP_STORAGE_COSMOS_KEY=

# -----------------------------------------------------------------------------
# Application Storage — Blob Storage (Azure mode)
# -----------------------------------------------------------------------------
APP_AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
# Credential type: "default_azure_credential" or "account_key"
APP_AZURE_STORAGE_CREDENTIAL_TYPE=default_azure_credential
# Only required when APP_AZURE_STORAGE_CREDENTIAL_TYPE=account_key
APP_AZURE_STORAGE_KEY=

# -----------------------------------------------------------------------------
# Key Vault
# -----------------------------------------------------------------------------
KEY_VAULT_ENDPOINT=

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large

# -----------------------------------------------------------------------------
# GitHub Copilot SDK
# -----------------------------------------------------------------------------
# GitHub Personal Access Token with 'copilot' scope
GITHUB_COPILOT_TOKEN=ghp_your-github-token
# Path to the Copilot CLI executable (default: "copilot")
COPILOT_CLI_PATH=copilot
# URL of an existing Copilot CLI server (leave empty for stdio transport)
COPILOT_CLI_URL=
# Default LLM model for agent sessions
COPILOT_MODEL=claude-opus-4.6

# -----------------------------------------------------------------------------
# MCP Server (Azure tools sidecar)
# -----------------------------------------------------------------------------
# Leave empty for stdio mode. Set to sidecar URL (e.g. http://azure-mcp:5008) for HTTP mode.
AZURE_MCP_SERVER_URL=
AZURE_MCP_COLLECT_TELEMETRY_MICROSOFT=false
APPLICATIONINSIGHTS_CONNECTION_STRING=

# -----------------------------------------------------------------------------
# Azure Document Intelligence
# -----------------------------------------------------------------------------
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=

# -----------------------------------------------------------------------------
# Azure Speech Services
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# -----------------------------------------------------------------------------
# Azure DevOps
# -----------------------------------------------------------------------------
AZURE_DEVOPS_DEFAULT_ORG=
AZURE_DEVOPS_DEFAULT_PROJECT=
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_TENANT_ID=

# -----------------------------------------------------------------------------
# Power BI
# -----------------------------------------------------------------------------
POWERBI_WORKSPACE_ID=
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# SharePoint
# -----------------------------------------------------------------------------
SHAREPOINT_SITE_URL=
SHAREPOINT_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Microsoft Graph / Teams
# -----------------------------------------------------------------------------
MSGRAPH_TENANT_ID=
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_ACCESS_TOKEN=
MSGRAPH_USER_ID=
